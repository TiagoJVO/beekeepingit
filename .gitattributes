# Normalize line endings: LF in the repo, auto on checkout.
* text=auto eol=lf

# Windows-specific scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets (no diff / no EOL conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.gguf binary
*.tflite binary
*.bin binary

# Bundled fonts (client/fonts/, #243) — never line-ending-normalize a font
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
