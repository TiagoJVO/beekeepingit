{
  "realm": "beekeepingit",
  "enabled": true,
  "displayName": "BeekeepingIT",
  "displayNameHtml": "<b>BeekeepingIT</b>",
  "loginTheme": "keycloak.v2",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "verifyEmail": true,
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 2592000,
  "ssoSessionMaxLifespan": 2592000,
  "roles": {
    "realm": [
      {
        "name": "platform-operator",
        "description": "Ops/superadmin role for managing Keycloak/infra (auth.md §3.3) — not the app-layer admin/user distinction, which is organizations.memberships.role (see ADR-0004). Unassigned by default; out of the app's authZ path."
      }
    ]
  },
  "clients": [
    {
      "clientId": "beekeepingit-pwa",
      "name": "BeekeepingIT PWA",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:*",
        "http://keycloak.beekeepingit.local:8080/*",
        "https://keycloak.beekeepingit.local:8443/*",
        "https://keycloak.beekeepingit.local/*",
        "https://*.beekeepingit.local/*"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "beekeepingit-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "beekeepingit",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "id": "11111111-1111-4111-8111-111111111111",
      "username": "test.beekeeper@beekeepingit.local",
      "email": "test.beekeeper@beekeepingit.local",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Test",
      "lastName": "Beekeeper",
      "credentials": [
        {
          "type": "password",
          "value": "dev-password123",
          "temporary": false
        }
      ]
    }
  ]
}
