{
  "realm": "beekeepingit",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "clients": [
    {
      "clientId": "beekeepingit-pwa",
      "name": "BeekeepingIT PWA",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:*",
        "https://keycloak.beekeepingit.local/*",
        "https://*.beekeepingit.local/*"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "beekeepingit-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "beekeepingit",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "id": "11111111-1111-4111-8111-111111111111",
      "username": "test.beekeeper@beekeepingit.local",
      "email": "test.beekeeper@beekeepingit.local",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Test",
      "lastName": "Beekeeper",
      "credentials": [
        {
          "type": "password",
          "value": "dev-password123",
          "temporary": false
        }
      ]
    }
  ]
}
