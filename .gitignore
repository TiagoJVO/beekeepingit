# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editors / IDEs ---
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
*.swp
*~

# --- Secrets / local env ---
.env
.env.*
!.env.example
*.local
secrets/
*.pem
*.key

# --- Logs / temp ---
*.log
logs/
tmp/
.cache/

# --- Build / dependency output (extended per-stack once chosen) ---
node_modules/
dist/
build/
out/
coverage/
*.class
bin/
obj/
target/
.dart_tool/
.flutter-plugins*
vendor/

# --- Helm ---
Chart.lock
**/charts/*.tgz

# --- Dev tooling (mise / go-task / lefthook) ---
.task/                 # go-task cache
mise.local.toml        # personal mise overrides (not committed)
.mise.local.toml
lefthook-local.yml     # personal lefthook overrides

# --- Go ---
# Per-service static binary the CI build step / local deploy compiles before
# `docker build` (the distroless image just COPYs it) — never committed (#23).
services/*/app

# --- Misc ---
*.tsbuildinfo

# --- Generated tool reports (ecc tooling) ---
# Point-in-time run logs (e.g. /ecc:update-codemaps' analysis report) — regenerated on
# every run, not meant to accumulate history in git.
.reports/
